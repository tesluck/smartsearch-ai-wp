{
  "name": "smartsearch-ai-wp",
  "version": "1.0.0",
  "description": "Intelligent natural language search plugin for WordPress. Visitors describe their problem, SmartSearch AI finds the right service.",
  "author": "MrTask <hello@mrtask.com> (https://mrtask.com)",
  "license": "GPL-2.0-or-later",
  "homepage": "https://smartsearchai.dev",
  "repository": {
    "type": "git",
