  },
  "bugs": {
    "url": "https://github.com/mrtask/smartsearch-ai-wp/issues"
  },
  "keywords": [
    "wordpress",
    "search",
    "ai",
    "natural-language",
    "autocomplete",
    "service-directory",
    "fuzzy-search",
    "intent-matching"
  ],
  "scripts": {
    "build": "cd smartsearch-ai && zip -r ../dist/smartsearch-ai.zip . -x '*.DS_Store' '*__MACOSX*'",
    "lint:php": "phpcs --standard=WordPress smartsearch-ai/ --extensions=php",
    "lint:fix": "phpcbf --standard=WordPress smartsearch-ai/ --extensions=php",
    "version": "node -e \"console.log(require('./package.json').version)\""
  },
  "engines": {
    "node": ">=16.0.0"
  }
